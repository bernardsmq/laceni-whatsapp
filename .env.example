# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000

# Google Sheets (Service Account - Direct Integration)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"laceni-whatsapp",...}
GOOGLE_SHEETS_ID=1F3aKZ-yKOdww3AxO7Dc8DeQb-AN1MfWOiEo430_R6Y4

# Google Sheets (OAuth - Legacy, optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google-sheets/callback

# Meta WhatsApp
META_WHATSAPP_CLIENT_ID=your-meta-client-id
META_WHATSAPP_CLIENT_SECRET=your-meta-client-secret
META_WHATSAPP_REDIRECT_URI=http://localhost:3000/api/auth/meta-whatsapp/callback

# FastAPI
FASTAPI_ENV=development
SECRET_KEY=your-secret-key-for-jwt

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/laceni
